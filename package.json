{
  "name": "gtm-signal-orchestrator",
  "version": "0.1.0",
  "description": "Open-source GTM engineering workspace for ingesting buyer signals, scoring accounts, routing leads, and powering operator workflows.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mohit4022-cloud/GTM-Signal-Orchestrator.git"
  },
  "keywords": [
    "gtm-engineering",
    "revops",
    "sales-ops",
    "marketing-ops",
    "lead-routing",
    "account-scoring",
    "signal-orchestration",
    "nextjs",
    "prisma",
    "typescript"
  ],
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "seed": "npm run db:seed",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:verify-seed": "tsx prisma/verify-seed.ts",
    "db:verify-contracts": "tsx prisma/verify-contracts.ts",
    "db:verify-signal-pipeline": "tsx prisma/verify-signal-pipeline.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "test": "node --import tsx --test --test-concurrency=1 tests/*.test.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
