generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Segment {
  SMB
  MID_MARKET
  ENTERPRISE
  STRATEGIC
}

enum Geography {
  NA_EAST
  NA_WEST
  EMEA
  APAC
}

enum AccountTier {
  TIER_3
  TIER_2
  TIER_1
  STRATEGIC
}

enum LifecycleStage {
  PROSPECT
  ENGAGED
  SALES_READY
  CUSTOMER
  NURTURE
}

enum AccountStatus {
  HEALTHY
  WATCH
  HOT
  AT_RISK
}

enum LeadStatus {
  NEW
  WORKING
  QUALIFIED
  NURTURING
  DISQUALIFIED
}

enum Temperature {
  COLD
  WARM
  HOT
  URGENT
}

enum SignalType {
  WEBSITE_VISIT
  PRICING_PAGE_VISIT
  HIGH_INTENT_PAGE_CLUSTER_VISIT
  FORM_FILL
  WEBINAR_REGISTRATION
  PRODUCT_SIGNUP
  PRODUCT_USAGE_MILESTONE
  EMAIL_REPLY
  MEETING_BOOKED
  MEETING_NO_SHOW
  THIRD_PARTY_INTENT_EVENT
  MANUAL_SALES_NOTE
  ACCOUNT_STATUS_UPDATE
}

enum SignalStatus {
  RECEIVED
  NORMALIZED
  MATCHED
  UNMATCHED
  ERROR
}

enum SignalCategory {
  WEB_ACTIVITY
  CONVERSION
  PRODUCT
  SALES_ENGAGEMENT
  SALES_ACTIVITY
  INTENT
  MANUAL
  ACCOUNT_CHANGE
}

enum SignalStrength {
  NONE
  LOW
  MEDIUM
  HIGH
}

enum ScoreEntityType {
  ACCOUNT
  LEAD
}

enum ScoreComponent {
  FIT
  INTENT
  ENGAGEMENT
  RECENCY
  PRODUCT_USAGE
  MANUAL_PRIORITY
}

enum RoutingReason {
  NAMED_ACCOUNT
  TERRITORY_SEGMENT
  ROUND_ROBIN
  STRATEGIC_ESCALATION
  OPS_REVIEW
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
}

enum TaskType {
  CALL
  EMAIL
  RESEARCH
  HANDOFF
  REVIEW
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AuditEventType {
  SIGNAL_INGESTED
  SIGNAL_NORMALIZED
  IDENTITY_RESOLVED
  SIGNAL_UNMATCHED_QUEUED
  SIGNAL_DUPLICATE_SKIPPED
  SIGNAL_INGEST_ERROR
  SCORE_UPDATED
  SCORE_RECOMPUTED
  SCORE_THRESHOLD_CROSSED
  SCORE_MANUAL_PRIORITY_OVERRIDDEN
  SIGNAL_ATTACHED_AND_RESCORED
  ROUTE_ASSIGNED
  TASK_CREATED
  SLA_BREACHED
  USER_OVERRIDE
  RULE_CONFIG_CHANGED
}

enum ScoreTriggerType {
  SIGNAL_INGESTED
  SIGNAL_ATTACHED
  MANUAL_PRIORITY_CHANGED
  RELATIONSHIP_CHANGED
  MANUAL_RECOMPUTE
}

model User {
  id                 String            @id
  name               String
  email              String            @unique
  role               String
  team               String
  geography          Geography
  title              String?
  avatarColor        String?
  ownedAccounts      Account[]         @relation("NamedOwner")
  assignedLeads      Lead[]            @relation("LeadOwner")
  ownedTasks         Task[]            @relation("TaskOwner")
  routingAssignments RoutingDecision[] @relation("RoutingOwner")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

model Account {
  id                String            @id
  name              String
  domain            String            @unique
  segment           Segment
  industry          String
  geography         Geography
  employeeCount     Int
  annualRevenueBand String
  namedOwnerId      String?
  accountTier       AccountTier
  lifecycleStage    LifecycleStage
  fitScore          Int
  intentScore       Int               @default(0)
  engagementScore   Int               @default(0)
  recencyScore      Int               @default(0)
  productUsageScore Int               @default(0)
  manualPriorityScore Int             @default(0)
  manualPriorityBoost Int             @default(0)
  manualPriorityNote String?
  manualPriorityUpdatedAt DateTime?
  overallScore      Int
  temperature       Temperature       @default(COLD)
  status            AccountStatus
  scoreBreakdownJson Json             @default("{}")
  scoreReasonCodesJson Json           @default("[]")
  scoreExplanationJson Json           @default("{}")
  scoreLastComputedAt DateTime?
  scoringVersion    String            @default("scoring/v1")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  namedOwner        User?             @relation("NamedOwner", fields: [namedOwnerId], references: [id])
  contacts          Contact[]
  leads             Lead[]
  signals           SignalEvent[]
  tasks             Task[]
  routingDecisions  RoutingDecision[]
  auditLogs         AuditLog[]
  scoreHistory      ScoreHistory[]

  @@index([segment, geography])
  @@index([overallScore])
  @@index([temperature, overallScore])
  @@index([namedOwnerId])
}

model Contact {
  id          String      @id
  accountId   String
  firstName   String
  lastName    String
  email       String      @unique
  title       String
  department  String
  seniority   String
  phone       String?
  personaType String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  leads       Lead[]
  signals     SignalEvent[]

  @@index([accountId])
}

model Lead {
  id              String             @id
  accountId       String
  contactId       String?
  source          String
  inboundType     String
  currentOwnerId  String?
  status          LeadStatus
  fitScore        Int                @default(0)
  intentScore     Int                @default(0)
  engagementScore Int                @default(0)
  recencyScore    Int                @default(0)
  productUsageScore Int              @default(0)
  manualPriorityScore Int            @default(0)
  manualPriorityBoost Int            @default(0)
  manualPriorityNote String?
  manualPriorityUpdatedAt DateTime?
  score           Int
  temperature     Temperature
  scoreBreakdownJson Json            @default("{}")
  scoreReasonCodesJson Json          @default("[]")
  scoreExplanationJson Json          @default("{}")
  scoreLastComputedAt DateTime?
  scoringVersion  String             @default("scoring/v1")
  slaDeadlineAt   DateTime?
  firstResponseAt DateTime?
  routedAt        DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  account         Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact         Contact?           @relation(fields: [contactId], references: [id], onDelete: SetNull)
  currentOwner    User?              @relation("LeadOwner", fields: [currentOwnerId], references: [id], onDelete: SetNull)
  signals         SignalEvent[]
  routingDecisions RoutingDecision[]
  tasks           Task[]
  scoreHistory    ScoreHistory[]
  auditLogs       AuditLog[]

  @@index([accountId])
  @@index([currentOwnerId])
  @@index([status, temperature])
}

model SignalEvent {
  id                    String         @id
  sourceSystem          String
  eventType             SignalType
  accountDomain         String?
  contactEmail          String?
  accountId             String?
  contactId             String?
  leadId                String?
  eventCategory         SignalCategory   @default(MANUAL)
  intentStrength        SignalStrength   @default(NONE)
  engagementStrength    SignalStrength   @default(NONE)
  payloadSummary        String           @default("")
  rawPayloadJson        Json
  normalizedPayloadJson Json
  identityResolutionCodesJson Json       @default("[]")
  occurredAt            DateTime
  receivedAt            DateTime
  dedupeKey             String         @unique
  status                SignalStatus
  errorMessage          String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @default(now()) @updatedAt
  account               Account?       @relation(fields: [accountId], references: [id], onDelete: SetNull)
  contact               Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead                  Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  triggeredScoreHistory ScoreHistory[] @relation("ScoreHistoryTriggerSignal")

  @@index([accountId])
  @@index([leadId])
  @@index([accountId, occurredAt])
  @@index([accountId, occurredAt, status])
  @@index([contactId, occurredAt])
  @@index([status, createdAt])
  @@index([status, occurredAt])
  @@index([accountDomain])
  @@index([contactEmail])
}

model ScoreHistory {
  id                   String           @id
  entityType           ScoreEntityType
  entityId             String
  accountId            String?
  leadId               String?
  previousScore        Int
  newScore             Int
  delta                Int
  previousTemperature  Temperature
  newTemperature       Temperature
  componentBreakdownJson Json
  reasonCodesJson      Json
  explanationJson      Json
  triggerType          ScoreTriggerType
  triggerSignalId      String?
  triggerMetadataJson  Json?
  scoringVersion       String
  createdAt            DateTime         @default(now())
  account              Account?         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  lead                 Lead?            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  triggerSignal        SignalEvent?     @relation("ScoreHistoryTriggerSignal", fields: [triggerSignalId], references: [id], onDelete: SetNull)

  @@index([accountId, createdAt])
  @@index([leadId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([triggerSignalId, createdAt])
}

model RoutingDecision {
  id              String        @id
  leadId          String?
  accountId       String?
  policyVersion   String
  decisionType    RoutingReason
  assignedOwnerId String?
  assignedTeam    String
  assignedQueue   String
  explanation     String
  createdAt       DateTime      @default(now())
  lead            Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  account         Account?      @relation(fields: [accountId], references: [id], onDelete: SetNull)
  assignedOwner   User?         @relation("RoutingOwner", fields: [assignedOwnerId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([leadId])
  @@index([assignedOwnerId])
}

model Task {
  id          String       @id
  leadId      String?
  accountId   String?
  ownerId     String?
  taskType    TaskType
  priority    TaskPriority
  dueAt       DateTime
  status      TaskStatus
  title       String
  description String
  createdAt   DateTime     @default(now())
  completedAt DateTime?
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  account     Account?     @relation(fields: [accountId], references: [id], onDelete: SetNull)
  owner       User?        @relation("TaskOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([leadId])
  @@index([ownerId])
  @@index([status, dueAt])
}

model AuditLog {
  id          String         @id
  eventType   AuditEventType
  actorType   String
  actorName   String
  entityType  String
  entityId    String
  accountId   String?
  leadId      String?
  beforeState Json?
  afterState  Json?
  explanation String
  createdAt   DateTime       @default(now())
  account     Account?       @relation(fields: [accountId], references: [id], onDelete: SetNull)
  lead        Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([accountId, createdAt])
  @@index([leadId, createdAt])
  @@index([eventType, createdAt])
}

model RuleConfig {
  id         String   @id
  ruleType   String
  version    String
  isActive   Boolean  @default(false)
  configJson Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([ruleType, isActive])
}
